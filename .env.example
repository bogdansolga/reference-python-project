# --- Chat backend (Anthropic) ---

# Direct Anthropic API (trainer / local demos). Required for the direct backend.
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional: Claude model for /api/chat (default: claude-sonnet-4-6).
# Use claude-opus-4-8 for heavier reasoning. Current ids are bare names.
# CHAT_MODEL=claude-sonnet-4-6
# CHAT_MAX_TOKENS=1024

# --- Claude on Vertex AI (GCP path) ---
# Set ANTHROPIC_VERTEX_PROJECT_ID to route /api/chat through Vertex instead of
# a direct key. Auth then comes from gcloud Application Default Credentials
# (`gcloud auth application-default login`) — no API key needed.
# Region: europe-west1 (EU) carries Sonnet 4.6 and Opus 4.6.
# ANTHROPIC_VERTEX_PROJECT_ID=your-gcp-project-id
# CLOUD_ML_REGION=europe-west1

# --- RAG generation backend (scripts/rag) ---
# vertex (default) = Claude on Vertex (the ING path). direct = use ANTHROPIC_API_KEY
# above for generation (rehearsal / fallback while Vertex Claude quota is pending).
# Embeddings always run on Vertex regardless.
# RAG_GEN_BACKEND=vertex
