# --- Chat backend (Anthropic) ---

# Direct Anthropic API (trainer / local demos). Required for the direct backend.
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional: Claude model for /api/chat (default: claude-haiku-4-5)
# CHAT_MODEL=claude-haiku-4-5
# CHAT_MAX_TOKENS=1024

# --- Claude on Vertex AI (GCP path) ---
# Set ANTHROPIC_VERTEX_PROJECT_ID to route /api/chat through Vertex instead of
# a direct key. Auth then comes from gcloud Application Default Credentials
# (`gcloud auth application-default login`) — no API key needed.
# On Vertex, CHAT_MODEL must be the date-suffixed id, e.g. claude-haiku-4-5@20251001.
# ANTHROPIC_VERTEX_PROJECT_ID=your-gcp-project-id
# CLOUD_ML_REGION=us-east5
